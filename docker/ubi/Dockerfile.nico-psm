# Build stage
FROM registry.access.redhat.com/ubi10/go-toolset:latest AS builder
ENV CGO_ENABLED=0

USER root
WORKDIR /workspace

COPY go.mod go.sum VERSION ./
COPY sdk/standard/go.mod ./sdk/standard/
RUN --mount=type=cache,target=/root/go/pkg/mod   \
    go mod download

COPY common/ ./common/
COPY db/ ./db/
COPY powershelf-manager/ ./powershelf-manager/

USER root
WORKDIR /workspace/powershelf-manager
RUN --mount=type=cache,target=/root/go/pkg/mod   \
    --mount=type=cache,target=/root/.cache/go-build   \
    go build \
        -ldflags "-extldflags '-static' -w -s" \
        -o /app/psm \
        .

# Runtime stage
FROM registry.access.redhat.com/ubi10/ubi-micro:latest

WORKDIR /app

COPY --from=builder /app/psm /app/psm

USER 1001

EXPOSE 50051

ENTRYPOINT ["/app/psm", "serve"]
